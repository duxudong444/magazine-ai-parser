# Local development settings.
# Copy this file to .env.local, then fill in at least one provider key.

# Server port
PORT=3000

# Frontend defaults loaded by Vite.
# These are optional; if left blank you can still enter keys in the UI.
VITE_AI_PROVIDER=gemini

# Gemini
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-3-flash-preview

# DeepSeek
VITE_DEEPSEEK_API_KEY=
VITE_DEEPSEEK_MODEL=deepseek-chat

# Optional custom prompt. Keep it on one line or use \n.
VITE_GLOBAL_PROMPT=
